        let currentQuestionIndex = 0;
        let score = 0;
        let selectedOption = null;
        let nameStudent = "Detektif Cilik Hebat";

        function startQuiz() {
            playClickSound();
            
            // Ask for student name for certificate with a prompt custom modal feel
            const inputName = prompt("Masukkan namamu untuk sertifikat kelulusan kelak:", "Detektif Cilik Hebat");
            if (inputName && inputName.trim() !== "") {
                nameStudent = inputName.trim();
            } else {
                nameStudent = "Detektif Cilik Hebat";
            }

            document.getElementById('quiz-start-screen').classList.add('hidden');
            document.getElementById('quiz-play-screen').classList.remove('hidden');
            document.getElementById('quiz-result-screen').classList.add('hidden');

            currentQuestionIndex = 0;
            score = 0;
            loadQuestion();
        }

        function loadQuestion() {
            selectedOption = null;
            document.getElementById('next-q-btn').classList.add('hidden');
            
            const q = quizData[currentQuestionIndex];
            
            // Update UI trackers
            document.getElementById('current-q-num').innerText = currentQuestionIndex + 1;
            document.getElementById('current-score').innerText = score;
            
            // Update Progress Bar
            const percent = ((currentQuestionIndex + 1) / quizData.length) * 100;
            document.getElementById('quiz-progress').style.width = `${percent}%`;

            // Setup Question text
            document.getElementById('question-text').innerText = q.question;

            // Setup Reading Box
            const readBox = document.getElementById('reading-box');
            if (q.reading && !isListeningQuestion(q.id)) {
                readBox.innerText = q.reading;
                readBox.classList.remove('hidden');
            } else {
                readBox.classList.add('hidden');
            }

            // Setup Audio section if it's a listening question (IDs: 4, 10, 16)
            const audioSec = document.getElementById('quiz-audio-section');
            const transcriptBox = document.getElementById('transcript-box');
            transcriptBox.classList.add('hidden');
            
            if (isListeningQuestion(q.id)) {
                audioSec.classList.remove('hidden');
                transcriptBox.innerText = q.reading;
            } else {
                audioSec.classList.add('hidden');
            }

            // Render options
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';

            q.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "p-4 rounded-2xl bg-gray-100 hover:bg-emerald-50 border-2 border-gray-300 text-left font-bold text-gray-800 text-sm md:text-base transition-all transform hover:-translate-y-0.5 active:translate-y-0.5 flex gap-3 items-center";
                btn.onclick = () => selectOption(idx, btn);
                
                // Add labels A, B, C, D
                const labels = ["A", "B", "C", "D"];
                btn.innerHTML = `<span class="bg-indigo-200 text-indigo-950 px-2.5 py-1 rounded-lg text-xs font-black border border-indigo-300">${labels[idx]}</span> <span class="flex-1">${opt}</span>`;
                optionsContainer.appendChild(btn);
            });
        }

        function isListeningQuestion(id) {
            return id === 4 || id === 10 || id === 16;
        }

        function speakQuizText() {
            const q = quizData[currentQuestionIndex];
            speakNow(q.reading);
        }

        function toggleTranscript() {
            playClickSound();
            const box = document.getElementById('transcript-box');
            if (box.classList.contains('hidden')) {
                box.classList.remove('hidden');
            } else {
                box.classList.add('hidden');
            }
        }

        function selectOption(idx, clickedBtn) {
            if (selectedOption !== null) return; // Prevent double clicking answer
            
            selectedOption = idx;
            const q = quizData[currentQuestionIndex];
            const isCorrect = (idx === q.correct);

            // Audio feedback
            if (isCorrect) {
                playCorrectSound();
                score += 5; // Max 100 points (20 * 5)
                document.getElementById('current-score').innerText = score;
                clickedBtn.classList.remove('bg-gray-100', 'border-gray-300', 'hover:bg-emerald-50');
                clickedBtn.classList.add('bg-emerald-400', 'text-white', 'border-emerald-600', 'btn-shadow-green');
            } else {
                playWrongSound();
                clickedBtn.classList.remove('bg-gray-100', 'border-gray-300', 'hover:bg-emerald-50');
                clickedBtn.classList.add('bg-rose-400', 'text-white', 'border-rose-600');
                
                // Highlight the correct answer
                const optionsContainer = document.getElementById('options-container');
                const correctBtn = optionsContainer.children[q.correct];
                correctBtn.classList.remove('bg-gray-100', 'border-gray-300', 'hover:bg-emerald-50');
                correctBtn.classList.add('bg-emerald-400', 'text-white', 'border-emerald-600');
            }

            // Show next button
            document.getElementById('next-q-btn').classList.remove('hidden');
        }

        function nextQuestion() {
            playClickSound();
            currentQuestionIndex++;
            if (currentQuestionIndex < quizData.length) {
                loadQuestion();
            } else {
                finishQuiz();
            }
        }

        function finishQuiz() {
            playVictorySound();
            document.getElementById('quiz-play-screen').classList.add('hidden');
            document.getElementById('quiz-result-screen').classList.remove('hidden');

            document.getElementById('final-score').innerText = score;
            document.getElementById('correct-wrong-summary').innerText = `Jawaban Benar: ${score / 5} / 20 Soal`;
            document.getElementById('cert-student-name').innerText = nameStudent;

            const emojiEl = document.getElementById('result-emoji');
            if (score >= 80) {
                emojiEl.innerText = "👑🏆✨";
            } else if (score >= 60) {
                emojiEl.innerText = "⭐🧗‍♂️👍";
            } else {
                emojiEl.innerText = "📚💪💡";
            }
        }

        function restartQuiz() {
            playClickSound();
            startQuiz();
        }

        // Initialize App on Window load
        window.onload = function() {
            switchTab('home');
            resetSteps();
        };
    </script>
